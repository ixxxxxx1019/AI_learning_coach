# ============================================================
# AI学习教练 — 环境变量配置模板
# ============================================================
# 使用方法：
#   1. 复制此文件为 .env ：cp .env.example .env
#   2. 填入你的真实 API Key
#   3. 切勿将 .env 提交到 Git！
# ============================================================

# DeepSeek API（必须）— 在 https://platform.deepseek.com 获取
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# LLM 配置（可选）
DEFAULT_MODEL=deepseek-chat
LLM_TEMPERATURE_CREATIVE=0.5
LLM_TEMPERATURE_STRUCTURED=0.1
LLM_MAX_TOKENS=4096

# LangSmith 追踪（可选）— 在 https://smith.langchain.com 获取
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2_pt_your-langsmith-key-here
# LANGCHAIN_PROJECT=ai-coach-langchain
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Redis 缓存（可选）
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL_SECONDS=3600

# 持久化
# CHECKPOINTER_TYPE=memory  # memory | sqlite | postgres
# SQLITE_DB_PATH=data/checkpoints.db
# POSTGRES_URL=postgresql://user:pass@localhost:5432/aicoach

# 日志
LOG_LEVEL=INFO
LOG_FORMAT=console  # console | json

# 应用
APP_NAME=AI学习教练
APP_PORT=8501
